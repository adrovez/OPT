@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card  border-primary">
    <h4 class="card-header alert-primary"><i class="fa fa-print"></i> Pago Diario</h4>
    <div class="card-body">

        <form id="formIndex" name="formIndex" method="post" action="@Url.Action("Reporte","PagoDiario",new {area="Reportes" })">
            @Html.AntiForgeryToken()

            <div class="form-group row">
                @*<div class="col-sm-6">
                        <label>Empresa</label>
                        @Html.DropDownList("idEmpresa", (SelectList)ViewBag.Empresa, "--- TODOS ---", new { @class = "form-control form-control-sm" })
                    </div>*@
                <div class="col-sm-3">
                    <label>Fecha Desde</label>
                    <input type="text" id="pFechaDesde" name="pFechaDesde" value="" autocomplete="off" class="form-control form-control-sm" required />
                </div>
                <div class="col-sm-3">
                    <label>Fecha Hasta</label>
                    <input type="text" id="pFechaHasta" name="pFechaHasta" value="" autocomplete="off" class="form-control form-control-sm" required />
                </div>
            </div>
            <div class="form-group row">
                <div class="col-sm-12 text-right">
                    <br />
                    <button type="submit" class="btn btn-sm btn-primary"><i class="fa fa-print"></i> Generar</button>
                </div>
            </div>
        </form>
    </div>
</div>


@section Scripts{   
    <script src="~/Areas/Reportes/Scripts/PagoDiario.js?v=3"></script>

    <script>
        $(document).ready(function () {
            $('#pFechaDesde').datepicker({
                format: "dd/mm/yyyy",
                //startDate: '0d',
                language: "es",
                autoclose: true,
                todayHighlight: true
            });

            $('#pFechaHasta').datepicker({
                format: "dd/mm/yyyy",
                //startDate: '0d',
                language: "es",
                autoclose: true,
                todayHighlight: true
            });

        })
    </script>
}














