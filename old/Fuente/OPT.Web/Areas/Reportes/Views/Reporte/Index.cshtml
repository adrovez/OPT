
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card  border-primary">
    <h4 class="card-header alert-primary"><i class="fa fa-print"></i> Reportes</h4>
    <div class="card-body">

        <form id="formIndex" name="formIndex" method="post" action="@Url.Action("Reporte","Reporte",new {area="Reportes" })">
            @Html.AntiForgeryToken()

            <div class="form-group row">
                <div class="col-sm-3">
                    <label>Tipo Reporte</label>
                    <select id="TipoReporte" name="TipoReporte" class="form-control form-control-sm" required>
                        <option value="">--- SELECCIONAR ---</option>
                        <option value="1">CRISTALES</option>
                        <option value="2">LISTADO CUOTAS</option>
                        <option value="3">CONSOLIDADO VENTA ANUAL</option>
                        <option value="4">CONSOLIDADO VENTA DIARIA</option>
                    </select>
                </div>
                <div class="col-sm-3">
                    <label>Empresa</label>
                    @Html.DropDownList("idEmpresa", (SelectList)ViewBag.Empresa, "--- SELECCIONAR ---", new { @class = "form-control form-control-sm", @required = "required" })
                </div>
                <div class="col-sm-3">
                    <label>Fecha Desde</label>
                    <input type="text" id="FechaDesde" name="FechaDesde" value="" autocomplete="off" class="form-control form-control-sm" required />
                </div>
                <div class="col-sm-3">
                    <label>Fecha Hasta</label>
                    <input type="text" id="FechaHasta" name="FechaHasta" value="" autocomplete="off" class="form-control form-control-sm" required />
                </div>
            </div>
            <div class="form-group row">
                <div class="col-sm-12 text-right">
                    <br />
                    <button type="submit" class="btn btn-sm btn-primary"><i class="fa fa-print"></i> Generar</button>
                </div>
            </div>
        </form>
    </div>
</div>


@section Scripts{

    <script>
        $(document).ready(function () {
            $('#FechaDesde').datepicker({
                format: "dd/mm/yyyy",
                //startDate: '0d',
                language: "es",
                autoclose: true,
                todayHighlight: true
            });

            $('#FechaHasta').datepicker({
                format: "dd/mm/yyyy",
                //startDate: '0d',
                language: "es",
                autoclose: true,
                todayHighlight: true
            });

            $("#TipoReporte").change(function () {
                const id = $(this).val();
                $("#idEmpresa").val('')

                if (id == 3 || id == 4) {                   
                    $('#idEmpresa').removeAttr("required");
                }
                else {
                    $('#idEmpresa').prop("required", true);
                }
            })

        })
    </script>
}












