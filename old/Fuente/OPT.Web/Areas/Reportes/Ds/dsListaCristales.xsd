          <TableAdapter BaseClass="System.ComponentModel.Component" DataAccessorModifier="AutoLayout, AnsiClass, Class, Public" DataAccessorName="OPT_OrdenTrabajoAdapter" GeneratorDataComponentClassName="OPT_OrdenTrabajoAdapter" Name="OPT_OrdenTrabajo" UserDataComponentName="OPT_OrdenTrabajoAdapter">
            <MainSource>
              <DbSource ConnectionRef="DB_OpticaConnectionDS (Web.config)" DbObjectType="Unknown" FillMethodModifier="Public" FillMethodName="Fill" GenerateMethods="Both" GenerateShortCommands="false" GeneratorGetMethodName="GetData" GeneratorSourceName="Fill" GetMethodModifier="Public" GetMethodName="GetData" QueryType="Rowset" ScalarCallRetval="System.Object, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" UseOptimisticConcurrency="false" UserGetMethodName="GetData" UserSourceName="Fill">
                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>Select (SELECT Nombre FROM OPT_Sucursal AS Suc WHERE Suc.idSucursal = A.idSucursal ) as Sucursal
      ,(SELECT Empresa FROM OPT_Empresa AS Emp WHERE Emp.idEmpresa = A.idEmpresa ) as Empresa
	  ,A.idOT
	  ,A.RutCliente
	  ,(SELECT Nombre FROM OPT_Cliente AS Cli WHERE Cli.RutCliente = A.RutCliente) AS Nombre
	  ,CASE WHEN B.CheckLejos = 1 THEN B.LejosODEsferico	ELSE '' END AS LejosODEsferico
	  ,CASE WHEN B.CheckLejos = 1 THEN B.LejosODCilindro	ELSE '' END AS LejosODCilindro	
	  ,CASE WHEN B.CheckLejos = 1 THEN B.LejosODEje			ELSE '' END AS LejosODEje
	  ,CASE WHEN B.CheckLejos = 1 THEN B.LejosODObservacion	ELSE '' END AS LejosODObservacion
	  ,CASE WHEN B.CheckLejos = 1 THEN B.LejosOIEsferico	ELSE '' END AS LejosOIEsferico
	  ,CASE WHEN B.CheckLejos = 1 THEN B.LejosOICilindro	ELSE '' END AS LejosOICilindro	
	  ,CASE WHEN B.CheckLejos = 1 THEN B.LejosOIEje			ELSE '' END AS LejosOIEje		    
	  ,CASE WHEN B.CheckLejos = 1 THEN B.LejosOIObservacion	ELSE '' END AS LejosOIObservacion
	  ,CASE WHEN B.CheckLejos = 1 THEN B.LejosDPEsferico	ELSE '' END AS LejosDPEsferico	
	  ,CASE WHEN B.CheckLejos = 1 THEN B.LejosADDEsfera		ELSE '' END AS LejosADDEsfera	    
	  ,CASE WHEN B.CheckCerca = 1 THEN B.CercaODEsferico	ELSE '' END AS CercaODEsferico	
	  ,CASE WHEN B.CheckCerca = 1 THEN B.CercaODCilindro	ELSE '' END AS CercaODCilindro
	  ,CASE WHEN B.CheckCerca = 1 THEN B.CercaODEje			ELSE '' END AS CercaODEje
	  ,CASE WHEN B.CheckCerca = 1 THEN B.CercaODObservacion	ELSE '' END AS CercaODObservacion
	  ,CASE WHEN B.CheckCerca = 1 THEN B.CercaOIEsferico	ELSE '' END AS CercaOIEsferico
	  ,CASE WHEN B.CheckCerca = 1 THEN B.CercaOICilindro	ELSE '' END AS CercaOICilindro
	  ,CASE WHEN B.CheckCerca = 1 THEN B.CercaOIEje			ELSE '' END AS CercaOIEje 
	  ,CASE WHEN B.CheckCerca = 1 THEN B.CercaOIObservacion	ELSE '' END AS CercaOIObservacion
	  ,CASE WHEN B.CheckCerca = 1 THEN B.CercaDPEsferico	ELSE '' END AS CercaDPEsferico
	  ,CASE WHEN (B.CheckLejos = 1 AND (LEN(B.LejosODEsferico)&gt; 0 or LEN(B.LejosODCilindro)&gt;0)) Then COUNT(1) ELSE 0 END as CantidadLejosOD
	  ,CASE WHEN (B.CheckLejos = 1 AND (LEN(B.LejosOIEsferico)&gt; 0 or LEN(B.LejosOICilindro)&gt;0)) Then COUNT(1) ELSE 0 END as CantidadLejosOI
	  ,CASE WHEN (B.CheckCerca = 1 AND (LEN(B.CercaODEsferico)&gt; 0 or LEN(B.CercaODCilindro)&gt;0)) Then COUNT(1) ELSE 0 END as CantidadCercaOD
	  ,CASE WHEN (B.CheckCerca = 1 AND (LEN(B.CercaOIEsferico)&gt; 0 or LEN(B.CercaOICilindro)&gt;0)) Then COUNT(1) ELSE 0 END as CantidadCercaOI
	  ,CASE WHEN B.CheckUrgente = 1 THEN 'SI'
			ELSE 'NO' END as Urgente
	  ,CASE WHEN B.CheckCristalesLaboratorio = 1 THEN 'SI'
			ELSE 'NO' END as CristalLaboratorio
	  ,B.LejosDPObservacion
	  ,B.CercaDPObservacion
From OPT_OrdenDeTrabajo AS A
INNER JOIN OPT_RecetaCristales as B
		ON A.idOT = B.idOT
INNER JOIN OPT_BitacoraOT AS C 
		ON A.idOT = C.idOt
		AND C.idEstado = 1
WHERE A.idEmpresa = @idEmpresa 
  AND A.FechaAtencion BETWEEN @FechaDesde AND @FechaHasta
  AND (B.CheckLejos = 1 OR B.CheckCerca = 1)
GROUP BY A.idOT
	  ,A.idSucursal
	  ,A.idEmpresa
	  ,A.RutCliente	
	  ,B.CheckLejos
	  ,B.CheckCerca
	  ,B.LejosODEsferico
	  ,B.LejosODCilindro
	  ,B.LejosODEje
	  ,B.LejosODObservacion
	  ,B.LejosOIEsferico
	  ,B.LejosOICilindro
	  ,B.LejosOIEje
	  ,B.LejosOIObservacion
	  ,B.LejosDPEsferico
	  ,B.LejosADDEsfera
	  ,B.CercaODEsferico
	  ,B.CercaODCilindro
	  ,B.CercaODEje
	  ,B.CercaODObservacion
	  ,B.CercaOIEsferico
	  ,B.CercaOICilindro
	  ,B.CercaOIEje
	  ,B.CercaOIObservacion
	  ,B.CercaDPEsferico
	  ,B.CheckUrgente
	  ,B.CheckCristalesLaboratorio
	  ,B.LejosDPObservacion
	  ,B.CercaDPObservacion
ORDER BY A.idOT</CommandText>
