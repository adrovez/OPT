                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>SELECT A.FechaAtencion
	  ,COUNT(A.idOT) AS OTS
	  ,SUM(B.Monto)  AS TOTAL
	  ,C.FormaPago
FROM OPT_OrdenDeTrabajo as A 
INNER JOIN OPT_Abono AS B
		ON A.idOT = B.idOT
INNER JOIN OPT_FormaPago as C
		ON B.idFormaPago = C.idFormaPago
GROUP BY A.FechaAtencion
		,C.FormaPago
ORDER BY A.FechaAtencion DESC</CommandText>
