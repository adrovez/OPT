@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


 

<div class="card  border-primary">
    <h4 class="card-header alert-primary"><i class="fa fa-building"></i> Listado Empresa</h4>
    <div class="card-body">

        <form id="formIndex">
            @Html.AntiForgeryToken()

            <div class="form-group row">
                <div class="col-sm-6">
                    <label>Nombre</label>
                    <input type="text" id="Nombre" name="Nombre" class="form-control form-control-sm" data-tipo="Alfa" maxlength="100">
                </div>
                <div class="col-sm-6 text-right">
                    <br />
                    <button type="submit" class="btn btn-sm btn-primary"><i class="fa fa-search"></i> Buscar</button>
                    <a href="@Url.Action("Create","Empresa",new {area="Empresas" })" class="btn btn-sm btn-success"><i class="fa fa-plus"></i> Nuevo</a>
                    <a href="@Url.Action("Reporte","Empresa",new {area="Empresas" })" class="btn btn-sm btn-primary"><i class="fa fa-print"></i> Imprimir</a>
                </div>
            </div>

            <div class="form-group row">
                <div class="col-sm-12">
                    <div class="table-responsive" id="TableListaEmpresa">
                        @Html.Partial("_ParcialListaEmpresa")
                    </div>
                </div>
            </div>

        </form>

       
    </div>
</div>


@section Scripts{

    <script src="~/Scripts/js/ValidaUtil.js?v=3"></script>
    <script src="~/Areas/Empresas/Scripts/Empresa.Index.js?v=3"></script>
    <script type="text/javascript">
        ObjCliente.UrlPaginar = "@Url.Action("Paginar","Empresa",new {area="Empresas" })";
    </script>

}
