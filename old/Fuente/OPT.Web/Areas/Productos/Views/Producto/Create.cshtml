@{
    ViewBag.Title = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<form id="formCreate" name="formCreate" method="post" action="@Url.Action("Create","Producto",new {area="Productos" })">
    @Html.AntiForgeryToken()    
    <div class="card  border-primary">
        <h4 class="card-header alert-primary"><i class="fa fa-glasses"></i> Nuevo Producto</h4>
        <div class="card-body">
            <div class="form-row">
                <div class="col-sm-4">
                    <label>Fecha Ingreso</label>
                    <input type="text" id="FechaIngreso" name="FechaIngreso" value="@DateTime.Now.ToShortDateString()" class="form-control form-control-sm" readonly>
                </div>
                <div class="col-sm-4">
                    <label>Codigo</label>
                    <input type="text" id="Codigo" name="Codigo" value="" class="form-control form-control-sm mayusculas" data-tipo="AlfaNumeric" maxlength="20" required>
                </div>
                <div class="col-sm-4">
                    <label>Producto</label>
                    <input type="text" id="Producto" name="Producto" value="" class="form-control form-control-sm mayusculas" data-tipo="Descripcion" maxlength="50" placeholder="Marca-Producto-Color" required>
                </div>
            </div>
            <div class="form-row">
                <div class="col-sm-4">
                    <label>Stock</label>
                    <input type="text"  value="0" class="form-control form-control-sm" data-tipo="Numeric" maxlength="9" readonly>
                </div>
                <div class="col-sm-4">
                    <label>Stock Minimo</label>
                    <input type="text" id="StockMinimo" name="StockMinimo" value="0" class="form-control form-control-sm text-right" data-tipo="Numeric" maxlength="9" required>
                </div>
                <div class="col-sm-4">
                    <label>Stock Maximo</label>
                    <input type="text" id="StockMaximo" name="StockMaximo" value="0" class="form-control form-control-sm text-right" data-tipo="Numeric" maxlength="9" required>
                </div>
            </div>
            <div class="form-row">
                <div class="col-sm-4">
                    <label>Control Stock</label>
                    <select class="form-control" name="ControlStock">
                        <option value="true" selected>SI</option>
                        <option value="false"> NO </option>
                    </select>
                </div>               
            </div>
        </div>

        <div class="card-footer">
            <div class="form-group">
                <div class="col-sm-12 text-right">
                    <a href="@Url.Action("Index","Producto",new {area="Productos" })" class="btn btn-sm btn-danger"><i class="fa fa-arrow-left"></i> Volver</a>
                    <button type="submit" class="btn btn-sm btn-success"><i class="fa fa-save"></i> Guardar</button>
                </div>
            </div>
        </div>
    </div>

</form>

@section Scripts{

    <script src="~/Scripts/js/ValidaUtil.js?v=3"></script>
    <script src="~/Areas/Productos/Scripts/Producto.Create.js?v=3"></script>
    <script type="text/javascript">
        ObjProducto.UrlExiste = "@Url.Action("Existe", "Producto",new {area="Productos" })";
    </script>

}
