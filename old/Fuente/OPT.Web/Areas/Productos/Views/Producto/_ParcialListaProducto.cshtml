@model PagedList.IPagedList<OPT.Entidad.OPT_Producto>
@using PagedList.Mvc;
@{ 
    Layout = null;
}


<table class="table table-sm table-hover">
    <thead>
        <tr class="text-center">
            <th>Ingreso</th>
            <th>Codigo</th>
            <th>Producto</th>
            <th>Stock</th>
            <th>Accion</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var Item in Model)
        {
        <tr>
            <td class="text-center">@Item.FechaIngreso.ToShortDateString()</td>
            <td>@Item.Codigo</td>
            <td>@Item.Producto</td>
            <td class="text-right">@Item.Stock</td>
            <td class="text-center">
                <a href="@Url.Action("Edit","Producto",new {area="Productos", id=Item.idProducto })" class="btn btn-sm btn-outline-warning" title="Editar..."><i class="fa fa-edit"></i></a>
                <a href="@Url.Action("Regularizar","Producto",new {area="Productos", id=Item.idProducto })" class="btn btn-sm btn-outline-secondary" title="Regularizar..."><i class="fa fa-recycle"></i></a>
            </td>
        </tr>
        }
    </tbody>
    <tfoot>
        <tr class="text-center">
            <td colspan="6">
                Página @(Model.PageCount < Model.PageNumber ? 0 : Model.PageNumber) de @Model.PageCount
                @Html.PagedListPager(Model, pPageNumber => Url.Action("Paginar", "Producto", new { area = "Productos", pPageNumber }), new PagedListRenderOptions { FunctionToTransformEachPageLink = (liTag, aTag) => { aTag.Attributes.Add("name", "paginar"); liTag.InnerHtml = aTag.ToString(); return liTag; } })
            </td>
        </tr>
    </tfoot>
</table>