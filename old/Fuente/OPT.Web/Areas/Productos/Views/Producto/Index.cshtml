@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card  border-primary">
    <h4 class="card-header alert-primary"><i class="fa fa-glasses"></i> Listado Producto</h4>
    <div class="card-body">

        <form id="formIndex">
            @Html.AntiForgeryToken()

            <div class="form-group row">
                <div class="col-sm-8">
                    <label>Producto</label>
                    <input type="text" id="Producto" name="Producto" class="form-control form-control-sm" data-tipo="Descripcion" maxlength="50">
                </div>
                <div class="col-sm-4 text-right">
                    <br />
                    <button type="submit" class="btn btn-sm btn-primary"><i class="fa fa-search"></i> Buscar</button>
                    <a href="@Url.Action("Create","Producto",new {area= "Productos" })" class="btn btn-sm btn-success"><i class="fa fa-plus"></i> Nuevo</a>
                    <a href="@Url.Action("Reporte","Producto",new {area= "Productos" })"  class="btn btn-sm btn-primary"><i class="fa fa-print"></i> Imprimir</a>
                </div>
            </div>

            <div class="form-group row">
                <div class="col-sm-12">
                    <div class="table-responsive" id="TableListaProducto">
                        @Html.Partial("_ParcialListaProducto")
                    </div>
                </div>
            </div>
        </form>

    </div>
</div>


@section Scripts{

    <script type="text/javascript" src="~/Scripts/js/ValidaUtil.js?v=3"></script>
    <script type="text/javascript" src="~/Areas/Productos/Scripts/Producto.Index.js?v=3"></script>
    <script type="text/javascript">
        ObjProducto.UrlPaginar = "@Url.Action("Paginar","Producto",new {area="Productos" })";
    </script>

}
