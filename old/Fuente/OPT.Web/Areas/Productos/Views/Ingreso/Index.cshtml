@model IEnumerable<OPT.Entidad.OPT_ProductoDocumento>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card  border-primary">
    <h4 class="card-header alert-primary"><i class="fa fa-clipboard"></i> Listado Ingreso Compra</h4>
    <div class="card-body">

        <form id="formIndex" action="@Url.Action("Paginar","Ingreso",new {area="Productos" })">
            @Html.AntiForgeryToken()

            <div class="form-group row">
                <div class="col-sm-8">
                    <label>N° Documento</label>
                    <input type="text" id="Filtro" name="Filtro" data-tipo="SoloNumero" class="form-control form-control-sm" maxlength="10">
                </div>
                <div class="col-sm-4 text-right">
                    <br />
                    <button type="submit" class="btn btn-sm btn-primary"><i class="fa fa-search"></i> Buscar</button>
                    <a href="@Url.Action("Create","Ingreso",new {area="Productos" })" class="btn btn-sm btn-success"><i class="fa fa-plus"></i> Ingreso Compra</a>
                </div>
            </div>

            <div class="form-group row">
                <div class="col-sm-12">
                    <div class="table-responsive" id="TableListaIngreso">
                        @Html.Partial("_ParcialIndex")
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>


@section Scripts{

    <script type="text/javascript" src="~/Scripts/js/ValidaUtil.js?v=4"></script>
    <script src="~/Areas/Productos/Scripts/Ingreso.Index.js?v=3"></script>
}


