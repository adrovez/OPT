                                        </tr>
                                        <tr>
                                            <td>DP</td>
                                            <td>@Model.recetaCristales.CercaDPEsferico</td>
                                            <td></td>
                                            <td></td>
                                        </tr>
                                        <tr>
                                            <td>&emsp;</td>
                                            <td>&emsp;</td>
                                            <td>&emsp;</td>
                                            <td>&emsp;</td>
                                        </tr>
                                    </tbody>
                                </table>
