@model OPT.Web.Areas.Imprimir.Models.ImprimirOtResponse
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        body {
            font-size: 10px;
        }

        @@media all {
            .page-break {
                display: none;
            }
        }

        @@media print {
            .page-break {
                display: block;
                page-break-before: always;
            }
        }
    </style>
</head>
<body>

    <div id="main" class="container">
        <div class="card">
            <div class="card-header" style="text-align:center">
                <h2>Centro Optico BL</h2>
                <table>
                    <tr>
                        <td>Rut</td>
                        <td>76.352.228-8</td>
                    </tr>
                    <tr>
                        <td>Fono</td>
                        <td>+56934082615</td>
                    </tr>
                    <tr>
                        <td>Dirección</td>
                        <td>Agustinas 853 Of. 507</td>
                    </tr>
                </table>
            </div>
            <hr />
