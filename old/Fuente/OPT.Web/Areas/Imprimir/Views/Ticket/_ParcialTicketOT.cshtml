                <h4 style="text-align:center">NOTA DE VENTA Y AUTORIZACION DE DESCUENTO</h4>
                <div class="row mb-4">
                    <div class="col-sm-6">
                        <table width="80%">
                            <tr>
                                <td><strong>No. OT:</strong></td>
                                <td><strong>@Model.OT</strong></td>
                            </tr>
                            <tr>
                                <td>Fecha</td>
                                <td>@Model.FechaAtencion</td>
                            </tr>
                            <tr>
                                <td>Rut</td>
                                <td>@Model.RutCliente</td>
                            </tr>
                            <tr>
                                <td>Nombre</td>
                                <td>@Model.NombreCliente</td>
                            </tr>
                            <tr>
                                <td>Telefono:</td>
                                <td>@Model.Telefono</td>
                            </tr>
                            <tr>
                                <td>Empresa:</td>
                                <td>@Model.EmpresaCliente</td>
                            </tr>
                            <tr>
                                <td>Entrega:</td>
                                <td>@(Model.FechaEntrega +" | "+ Model.HoraEntrega)</td>
                            </tr>
                        </table>
                    </div>
                </div>
                <hr />
                <div class="table-responsive-sm">
                    <table width="80%">
                        <thead>
                            <tr>
                                <th>Un.</th>
                                <th>Detalle</th>
                                <th>Produc</th>
                                <th>Precio</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.ordenDeTrabajoDetalles)
                            {
                                <tr>
                                    <td style="text-align:right">@item.Cantidad</td>
                                    <td style="text-align:left">@item.Comentario</td>
                                    <td style="text-align:left">@item.OPT_Producto.Producto</td>
                                    <td style="text-align:right">@item.ValorUnitario.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <hr />
                <div class="row">
                    <div class="col-lg-4 col-sm-5 ml-auto">
                        <table width="80%">
                            <tbody>
                                <tr>
                                    <td>&emsp;&emsp;</td>
                                    <td><strong>Sub total</strong></td>
                                    <td style="text-align:right">@Model.Monto.ToString("N0")</td>
                                </tr>
