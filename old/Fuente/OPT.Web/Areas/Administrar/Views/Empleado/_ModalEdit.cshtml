@model OPT.Entidad.OPT_Usuario
@{
    Layout = null;
}
<div class="modal fade" id="myModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl" role="document">
        <div class="modal-content">
            <form id="formEditar" action="@Url.Action("Edit","Empleado",new {area="Administrar" })">
                @Html.AntiForgeryToken()
                <div class="modal-header alert-primary">
                    <h5 class="modal-title"><i class="fa fa-users"></i> EDITAR EMPLEADO</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="form-row">
                        <div class="col-sm-4">
                            <label class="col-form-label">Rut</label>
                            <input type="text" class="form-control" id="Rut" name="Rut" value="@Model.RutUsuario" readonly/>
                        </div>
                        <div class="col-sm-8">
                            <label class="col-form-label">Nombre</label>
                            <input type="text" class="form-control" id="Nombre" name="Nombre" value="@Model.Nombre" data-tipo="AlfaNumeric" maxlength="50" required />
                        </div>
                    </div>
                    <div class="form-group row">
                        <div class="col-sm-4">
                            <label class="col-form-label">Mail</label>
                            <input type="text" class="form-control" id="Mail" name="Mail" value="@Model.Mail" data-tipo="Email" maxlength="40" />
                        </div>
                        <div class="col-sm-4">
                            <label class="col-form-label">Fecha Ingreso</label>
                            <input type="text" class="form-control" id="FechaIngreso" name="FechaIngreso" value="@Model.FechaIngreso.ToString("dd/MM/yyyy")" readonly />
                        </div>
                        <div class="col-sm-4">
                            <label class="col-form-label">Clave</label>
                            <input type="password" class="form-control" id="Clave" name="Clave" value="@Model.Clave" maxlength="20" data-tipo="AlfaNumeric" required />
                        </div>
                    </div>
                    <div class="form-group row">
                        <div class="col-sm-4">
                            <label>Rol</label>
                            @Html.DropDownList("idRol", (SelectList)ViewBag.ComboRol, new { @class = "form-control", @required = "required", @data_placeholder = "--- SELECCIONAR ---" })
                        </div>
                        <div class="col-sm-4">
                            <label class="col-form-label">Sucursal</label>
                            @Html.DropDownList("idSucursal", ViewBag.ComboSucursal as IEnumerable<SelectListItem>, new { @class = "form-control", @required = "required", @data_placeholder = "--- SELECCIONAR ---", @multiple = "multiple" })
                        </div>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger btn-sm" data-dismiss="modal"><i class="fa fa-times"></i> Close</button>
                    <button type="submit" class="btn btn-success btn-sm"><i class="fa fa-save"></i> Guardar</button>
                </div>

            </form>
        </div>
    </div>
</div>

