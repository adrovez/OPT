@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="card  border-primary">
    <h4 class="card-header alert-primary"><i class="fa fa-users"></i> Listado Empleado</h4>
    <div class="card-body">
        <form id="formIndex" action="@Url.Action("Index","Empleado",new {area="Administrar" })">
            @Html.AntiForgeryToken()
            <div class="form-group row">
                <div class="col-sm-8">
                    <label>Filtro</label>
                    <input type="text" id="pFiltro" name="pFiltro" class="form-control form-control-sm" maxlength="50">
                </div>
                <div class="col-sm-4 text-right">
                    <br />
                    <button type="submit" class="btn btn-sm btn-primary"><i class="fa fa-search"></i> Buscar</button>
                    <a href="@Url.Action("Create","Empleado",new {area="Administrar" })" id="Nuevo" class="btn btn-sm btn-success"><i class="fa fa-plus"></i> Nuevo</a>
                    <a href="@Url.Action("Reporte","Empleado",new {area="Administrar" })" class="btn btn-sm btn-primary"><i class="fa fa-print"></i> Imprimir</a>
                </div>
            </div>
            <div class="form-group row">
                <div class="col-sm-12">
                    <div class="table-responsive" id="TablaDatos">
                        @Html.Partial("_ParcialBusqueda")
                    </div>
                </div>
            </div>

        </form>
    </div>
</div>


@section Scripts{
    <link href="~/Content/component-chosen.min.css" rel="stylesheet" />
    <script src="~/Scripts/chosen.jquery.min.js"></script>
    <script src="~/Scripts/js/ValidaUtil.js?v=3"></script>
    <script src="~/Areas/Administrar/Scripts/Empleado.js?v=3"></script>
}
