@model OPT.Entidad.OPT_Usuario
@{
    Layout = null;
}

<div class="modal fade" id="myModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header alert-primary">
                <h5 class="modal-title"><i class="fa fa-users"></i> DETALLE EMPLEADO</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-row">
                    <div class="col-sm-4">
                        <label>Nombre</label>
                        <input type="text" value="@Model.Nombre" class="form-control form-control-sm" readonly />
                    </div>
                    <div class="col-sm-4">
                        <label>Telefono</label>
                        <input type="text" value="@Model.Mail" class="form-control form-control-sm" readonly>
                    </div>
                    <div class="col-sm-4">
                        <label>Fecha Registro</label>
                        <input type="text" value="@Model.FechaIngreso.ToString("dd/MM/yyyy")" class="form-control form-control-sm" readonly>
                    </div>

                </div>
                <div class="form-row">
                    <div class="col-sm-4">
                        <label>Rol</label>
                        <input type="text" class="form-control" value="@Model.OPT_Rol.Rol" readonly />
                    </div>
                    <div class="col-sm-4">
                        <label>Sucursal</label>
                        @Html.DropDownList("SucursalAsignado", (SelectList)ViewBag.SucursalAsignado, new { @class = "form-control", @data_placeholder = "--- SELECCIONAR ---", @multiple = "multiple" })
                    </div>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger btn-sm" data-dismiss="modal"><i class="fa fa-times"></i> Close</button>
            </div>
        </div>
    </div>
</div>

