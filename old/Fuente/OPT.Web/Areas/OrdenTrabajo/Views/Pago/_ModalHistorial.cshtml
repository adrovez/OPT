@model IEnumerable<OPT.Entidad.OPT_OrdenDeTrabajo>
@{
    Layout = null;
}
<div class="modal fade bd-example-modal-lg" id="myModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header alert-success">
                <h5 class="modal-title"><i class="fa fa-money-bill"></i> HISTORIAL PAGO</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                    <div class="form-row">
                        <div class="col-sm-4">
                            <label>Empresa</label>
                            <input type="text" value="@ViewBag.Cliente.OPT_Empresa.Empresa" class="form-control form-control-sm" readonly />
                        </div>
                        <div class="col-sm-4">
                            <label>Rut</label>
                            <input type="text" value="@ViewBag.Cliente.RutCliente" class="form-control form-control-sm" readonly>
                        </div>
                        <div class="col-sm-4">
                            <label>Nombre</label>
                            <input type="text" value="@ViewBag.Cliente.Nombre" class="form-control form-control-sm" readonly>
                        </div>
                    </div>
                
                <br />
                <div class="form-row">
                    <div class="col-sm-12">

                        @foreach (var Item in Model)
                        {
                            <div class="card">
                                <div class="card-header"><h5 class="card-title">OT N° @Item.idOT - Fecha @Item.FechaAtencion</h5></div>

                                <div class="card-body">

                                    <div class="form-row">
                                        <div class="col-sm-3">
                                            <label>Precio</label>
                                            <input type="text" value="@Item.Precio" class="form-control form-control-sm text-right number" readonly />
                                        </div>
                                        <div class="col-sm-3">
                                            <label>Abono</label>
                                            <input type="text" value="@Item.Abono" class="form-control form-control-sm text-right number" readonly />
                                        </div>
                                        <div class="col-sm-3">
                                            <label>Saldo</label>
                                            <input type="text" value="@Item.Saldo" class="form-control form-control-sm text-right number" readonly />
                                        </div>
                                        <div class="col-sm-3">
                                            <label>Cuota</label>
                                            <input type="text" value="@Item.NumeroCuota" class="form-control form-control-sm text-right" readonly />
                                        </div>
                                    </div>
                                    <br />
                                    <div class="form-row">
                                        <div class="col-sm-12">
                                            <div class="table-responsive">
                                                <table class="table table-sm table-hover">
                                                    <thead>
                                                        <tr class="text-center">
                                                            <th>Fecha Pago</th>
                                                            <th>Monto</th>
                                                            <th>Tipo Pago</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var Item2 in Item.OPT_Pago)
                                                        {
                                                            <tr>
                                                                <td class="text-center">@Item2.FechaPago.ToShortDateString()</td>
                                                                <td class="text-right">@Item2.Monto.ToString("N0")</td>                                                                
                                                                <td class="text-center">@Item2.TipoPago</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        }




                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-danger btn-sm" data-dismiss="modal"><i class="fa fa-times"></i> Close</button>
                <a href="@Url.Action("ReportePagoOT","Pago",new {area="OrdenTrabajo", id=ViewBag.Cliente.RutCliente })" class="btn btn-sm btn-primary"><i class="fa fa-print"></i> Imprimir</a>
            </div>
        </div>
    </div>
</div>
