@model OPT.Web.Areas.OrdenTrabajo.Models.Pago.PagoMasivoView
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section CustomHeadContent{
    <link href="~/Content/component-chosen.min.css" rel="stylesheet" />
}

<div class="card  border-primary">
    <h4 class="card-header alert-primary"><i class="fa fa-donate"></i> Pago Masivo</h4>
    <div class="card-body">

        <form id="formIndex" action="@Url.Action("PagoMasivo","Pago",new {area="OrdenTrabajo" })">
            @Html.AntiForgeryToken()

            <div class="form-group row">
                <div class="col-sm-4">
                    <label>Empresa</label>
                    @Html.DropDownList("idEmpresa", Model.Empresas as IEnumerable<SelectListItem>, "--- SELECCIONAR ---", new { @class = "form-control form-control-sm", @required = "required" })
                </div>
                <div class="col-sm-4">
                    <label>Fecha Pago</label>
                    <input type="text" id="FechaPago" name="FechaPago" class="form-control form-control-sm" maxlength="10" required />
                </div>
                <div class="col-sm-4">
                    <label>Archivo</label>
                    <input type="file" id="Archivo" name="Archivo" class="form-control form-control-sm" accept=".xls,.xlsx" required>
                </div>
            </div>
            <div class="form-group">
                <div class="col-sm-12 text-right">
                    <br />
                    <a href="@Url.Action("Index","Deuda",new {area="OrdenTrabajo" })" class="btn btn-sm btn-danger"><i class="fa fa-arrow-left"></i> Volver</a>
                    <button type="submit" class="btn btn-sm btn-success"><i class="fa fa-save"></i> Guardar</button>
                </div>
            </div>

            <div class="form-group row">
                <div class="col-sm-12">
                    <div class="table-responsive">
                        <table class="table table-hover" id="TableError">
                            <thead>
                                <tr>
                                    <th>Fila</th>
                                    <th>Ot</th>                                    
                                    <th>Mensaje</th>
                                </tr>
                            </thead>
                            <tbody>

                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>


@section Scripts{
    <script type="text/javascript" src="~/Scripts/js/ValidaUtil.js?v=3"></script>
    <script src="~/Scripts/chosen.jquery.min.js"></script>
    <script src="~/Areas/OrdenTrabajo/Scripts/Pago.Masivo.js?v=3"></script>
}




