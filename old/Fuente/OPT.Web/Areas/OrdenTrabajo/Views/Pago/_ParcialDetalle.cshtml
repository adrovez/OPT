@{
    Layout = null;
}
<form id="formAbono" action="@Url.Action("Abono","Ingreso",new {area="OrdenTrabajo" })">
    @Html.AntiForgeryToken()
    <div class="form-group row">
        <div class="col-sm-4">
            <label>N° OT</label>
            <input type="text" class="form-control form-control-sm" readonly />
        </div>
        <div class="col-sm-4">
            <label>Rut</label>
            <input type="text" class="form-control form-control-sm" readonly />
        </div>
        <div class="col-sm-4">
            <label>Nombre</label>
            <input type="text" class="form-control form-control-sm" readonly />
        </div>
    </div>
        <div class="form-group row">
            <div class="col-sm-4">
                <div class="row">
                    <div class="col-sm-12">
                        <label>Deuda Total</label>
                        <input type="text" class="form-control form-control-sm" readonly />
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-12">
                        <label>Total Pagado</label>
                        <input type="text" class="form-control form-control-sm" readonly />
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-12">
                        <label>Saldo Pendiente</label>
                        <input type="text" class="form-control form-control-sm" readonly />
                    </div>
                </div>

            </div>

            <div class="col-sm-4">
                                      

                <table class="table table-sm table-hover" id="TableAbono">
                    <thead>
                        <tr>
                            <td class="text-center" colspan="3">Historial Pago</td>
                        </tr>
                        <tr class="text-center">
                            <th>Abona con</th>
                            <th>Monto Abono</th>
                            <th>Accion</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                    <tfoot>
                        <tr>
                            <td></td>
                            <td class="text-right font-weight-bold"></td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>


            </div>

            <div class="col-sm-4">
                <div class="form-group row">
                    <div class="col-sm-12">
                        <label>Monto a Pagar</label>
                        <input type="text" id="ValorCuota" name="ValorCuota" class="form-control form-control-sm text-right" data-tipo="Numeric" maxlength="2" required>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-sm-12">
                        <label>Forma Pago</label>
                        <input type="text" id="ValorCuota" name="ValorCuota" class="form-control form-control-sm text-right" data-tipo="Numeric" maxlength="2" required>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-sm-12  text-right">
                        <button type="button" id="btnVolverLente" class="btn btn-sm border-secondary"><i class="fa fa-arrow-left"></i> Volver</button>
                        <button type="submit" class="btn btn-sm btn-success"><i class="fa fa-arrow-right"></i> Finalizar</button>
                    </div>
                </div>
            </div>
        </div>
</form>

