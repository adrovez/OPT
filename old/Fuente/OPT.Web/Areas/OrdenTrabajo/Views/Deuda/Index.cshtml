@model IEnumerable<OPT.Entidad.sp_ListaDeudores_Result>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";

    long TotalDeuda = 0;
    long SaldoPendiente = 0;

}


<div class="card  border-primary">
    <h4 class="card-header alert-primary"><i class="fa fa-money-check"></i> Listado Deudores</h4>
    <div class="card-body">

        <form id="formIndex">
            @Html.AntiForgeryToken()

            <div class="form-group row">

                <div class="col-sm-12 text-right">
                    <br />
                    <a href="@Url.Action("PagoMasivo","Pago",new {area="OrdenTrabajo" })" class="btn btn-sm btn-success" ><i class="fa fa-donate"></i> Pago Masivo</a>
                    <a href="@Url.Action("Reporte","Deuda",new {area="OrdenTrabajo" })" class="btn btn-sm btn-primary" target="_blank"><i class="fa fa-print"></i> Imprimir</a>
                </div>
            </div>

            <div class="form-group row">
                <div class="col-sm-12">
                    <div class="table-responsive">
                        <table class="table table-sm table-hover">
                            <thead>
                                <tr class="text-center">
                                    <th>Empresa</th>
                                    <th>Cantidad OT</th>
                                    <th>Saldo Pendiente</th>                                   
                                    <th>Acción</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var Item in Model)
                                {
                                    SaldoPendiente = long.Parse(Item.Saldo.ToString()) - long.Parse(Item.Pagado.ToString());
                                    <tr>
                                        <td>@Item.Empresa</td>
                                        <td class="text-right number">@Item.OT</td>
                                        <td class="text-right number">@SaldoPendiente.ToString("N0")</td>                                                                         
                                        <td class="text-center">
                                            <a href="@Url.Action("Details","Deuda",new {area="OrdenTrabajo", id=Item.idEmpresa })" name="Ver" title="Detalle..." class="btn btn-sm btn-outline-primary"><i class="fa fa-file"></i></a>
                                        </td>
                                    </tr>

                                    TotalDeuda += SaldoPendiente;
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="2" class="text-right badge-dark">Total</td>
                                    <td class="text-right badge-dark">@TotalDeuda.ToString("N0")</td>                                    
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>


@section Scripts{

    <script src="~/Scripts/js/ValidaUtil.js?v=3"></script>
    <script src="~/Areas/OrdenTrabajo/Scripts/Deuda.Index.js?v=4"></script>

}
