@model OPT.Web.Areas.OrdenTrabajo.Models.OrdenTrabajoResponse

@{
    Layout = null;
    decimal Precio = Model.detalleOT.Sum(x => x.Cantidad * x.ValorUnitario);
    decimal Abono = Model.abonos.Sum(x => x.Monto);
    decimal Saldo = Precio- Abono;

}
<div class="row">
    <div class="col-sm-4">
        <form id="formAbono" action="@Url.Action("Abono","Ingreso",new {area="OrdenTrabajo" })">
            @Html.AntiForgeryToken()
            <input type="hidden" id="Precio" name="Precio" value="@Precio" />
            <input type="hidden" id="Abonos" name="Abono" value="@Abono" />
            <input type="hidden" id="Monto" name="Monto" value="0" />
            <div class="form-group row">
                <div class="col-sm-12">
                    <label>Total OT</label>
                    <input type="text" id="precio" value="@Precio.ToString("N0")" class="form-control form-control-sm text-right" data-tipo="Numeric" maxlength="10" readonly>
                </div>
            </div>
            <div class="form-group row">
                <div class="col-sm-12">
                    <label>Abona con</label>
                    @Html.DropDownList("idFormaPago", Model.ListFormaPago as IEnumerable<SelectListItem>, "--- SELECCIONAR ---", new { @class = "form-control form-control-sm", @required = "required" })
                </div>
            </div>
            <div class="form-group row">
                <div class="col-sm-12">
                    <label>Monto Abono</label>
                    <input type="text" id="Abono" class="form-control form-control-sm text-right" data-tipo="Numeric" maxlength="10" required>
                </div>
            </div>
            <div class="form-group row">
                <div class="col-sm-12">
                    <br />
                    <button type="submit" class="btn btn-success btn-sm btn-block" id="btnAgregarAbono"><i class="fa fa-plus"></i> Abonar</button>
                </div>
            </div>


        </form>
    </div>
    <div class="col-sm-4">
        <div class="form-group row">
            <div class="col-sm-12">
                <div class="table-responsive">
                    <table class="table table-sm table-hover" id="TableAbono">
                        <thead>
                            <tr class="text-center">
                                <th>Abona con</th>
                                <th>Monto Abono</th>
                                <th>Accion</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.abonos)
                            {
                                <tr>
                                    <td>@item.FormaPago</td>
                                    <td class="text-right">@item.Monto.ToString("N0")</td>
                                    <td class="text-center"><a href="@Url.Action("EliminaAbono", "Ingreso", new {area="OrdenTrabajo", id=item.idAbono })" type="button" name="EliminaFilaAbono" class="btn btn-sm btn-outline-danger" title="Eliminar..."><i class="fa fa-trash"></i></a></td>
                                </tr>
                            }

                        </tbody>
                        <tfoot>
                            <tr>
                                <td></td>
                                <td class="text-right font-weight-bold">@Abono.ToString("N0")</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">

        <form id="formFinaliza" action="@Url.Action("Finaliza","Ingreso",new {area="OrdenTrabajo" })">
            @Html.AntiForgeryToken()
            <div class="form-group row">
                <div class="col-sm-12">
                    <label>Saldo</label>
                    <input type="text" id="Saldo" name="Saldo" value="@Saldo.ToString("N0")" class="form-control form-control-sm text-right" data-tipo="Numeric" readonly>
                </div>
            </div>
            <div class="form-group row">
                <div class="col-sm-12">
                    <label>N° Cuotas</label>
                    <input type="text" id="NumeroCuota" name="NumeroCuota" class="form-control form-control-sm text-right" data-tipo="Numeric" maxlength="2" value="0" required>
                </div>
            </div>
            <div class="form-group row">
                <div class="col-sm-12">
                    <label>Valor Cuota</label>
                    <input type="text" id="ValorCuota" name="ValorCuota" class="form-control form-control-sm text-right" data-tipo="Numeric" maxlength="2" readonly>
                </div>
            </div>
            <div class="form-group row">
                <div class="col-sm-12">
                    <label>Fecha Inicio Pago</label>
                    <input type="text" id="InicioPago" name="InicioPago" class="form-control form-control-sm text-right" autocomplete="off" maxlength="10">
                </div>
            </div>

            <div class="form-group row">
                <div class="col-sm-12  text-right">
                    <button type="button" id="btnVolverLente" class="btn btn-sm border-secondary"><i class="fa fa-arrow-left"></i> Volver</button>
                    <button type="submit" class="btn btn-sm btn-success"><i class="fa fa-arrow-right"></i> Finalizar</button>
                </div>
            </div>
        </form>
    </div>
</div>





