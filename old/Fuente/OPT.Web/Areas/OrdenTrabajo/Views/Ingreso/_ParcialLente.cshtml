@model OPT.Web.Areas.OrdenTrabajo.Models.OrdenTrabajoResponse

@{
    Layout = null;
}

<div class="form-group row">
    <div class="col-sm-4">
        <div class="form-group row">
            <div class="col-sm-12">
                <label>Tipo Producto</label>
                @Html.DropDownList("idProducto", Model.producto.ListProducto as IEnumerable<SelectListItem>, "--- SELECCIONAR ---", new { @class = "form-control", @required = "required" })
            </div>
        </div>
        <div class="form-group row">
            <div class="col-sm-12">
                <label>Cantidad</label>
                <input type="text" id="Cantidad" name="Cantidad" class="form-control form-control-sm text-right" data-tipo="Numeric" maxlength="10" required>
            </div>
        </div>
        <div class="form-group row">
            <div class="col-sm-12">
                <label>Valor</label>
                <input type="text" id="Valor" name="Valor" class="form-control form-control-sm text-right" data-tipo="Numeric" maxlength="10" required>
            </div>
        </div>
        <div class="form-group row">
            <div class="col-sm-12">
                <label>Observación</label>
                <textarea type="text" id="Comentario" name="Comentario" class="form-control form-control-sm" rows="2" maxlength="250"></textarea>
            </div>
        </div>
        <div class="form-group row">
            <div class="col-sm-12">
                <button type="submit" id="btnAgregarProducto" class="btn btn-success btn-sm btn-block"><i class="fa fa-plus"></i> Agregar</button>
            </div>
        </div>
    </div>
    <div class="col-sm-8">
        <div class="form-group row">
            <div class="col-sm-12">
                <div class="table-responsive">
                    <table class="table table-sm table-hover" id="TableProducto">
                        <thead>
                            <tr class="text-center">
                                <th>Producto</th>
                                <th>Cantidad</th>
                                <th>Valor</th>
                                <th>Observación</th>
                                <th>Total</th>
                                <th>Accion</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                decimal total = 0;
                                decimal SumTotal = 0;

                                foreach (var item in Model.detalleOT)
                                {
                                    total = (item.ValorUnitario * item.Cantidad);
                                    SumTotal += total;
                                <tr>
                                <td>@item.OPT_Producto.Producto</td>
                                <td class="text-right">@item.Cantidad</td>
                                <td class="text-right">@item.ValorUnitario.ToString("N0")</td>
                                <td>@item.Comentario</td>
                                <td class="text-right">@total.ToString("N0")</td>
                                <td class="text-center"><a href="@Url.Action("EliminaLente", "Ingreso", new { area = "OrdenTrabajo", id = item.idOTDetalle })" type="button" name="EliminaFila" class="btn btn-sm btn-outline-danger" title="Eliminar..."><i class="fa fa-trash"></i></a></td>
                                </tr>
                                    }
                                }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td class="text-right font-weight-bold" colspan="4">TOTAL</td>
                                <td class="text-right font-weight-bold" id="tdTotalProducto">
                                    @SumTotal.ToString("N0")
                                    <input type="hidden" id="TotalProducto" value="@SumTotal" />
                                </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>


<div class="form-group row">
    <div class="col-sm-12  text-right">
        <button type="button" id="btnVolverReceta" class="btn btn-sm border-secondary"><i class="fa fa-arrow-left"></i> Volver</button>
        <button type="button" class="btn btn-sm btn-success" id="btnSiguienteAbono"><i class="fa fa-arrow-right"></i> Siguiente</button>
    </div>
</div>

