@model OPT.Entidad.OPT_Cliente
@{ 
    Layout = null;
}
<div class="modal fade" id="myModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header alert-primary">
                <h5 class="modal-title"><i class="fa fa-user"></i> DETALLE CLIENTE</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-row">
                    <div class="col-sm-4">
                        <label>Rut</label>
                        <input type="text" value="@Model.RutCliente" class="form-control form-control-sm" readonly>
                    </div>
                    <div class="col-sm-4">
                        <label>Nombre</label>
                        <input type="text" value="@Model.Nombre" class="form-control form-control-sm" readonly>
                    </div>
                    <div class="col-sm-4">
                        <label>Fecha Nacimiento</label>
                        <input type="text" value="@Model.FechaNacimiento" class="form-control form-control-sm" readonly />
                    </div>
                </div>
                <div class="form-row">
                    <div class="col-sm-4">
                        <label>Prevision</label>
                        <input type="text" value="@Model.TipoPrevision" class="form-control form-control-sm" readonly>
                    </div>
                    <div class="col-sm-8">
                        <label>Empresa</label>
                        <input type="text" value="@Model.OPT_Empresa.Empresa" class="form-control form-control-sm" readonly />
                    </div>
                </div>

                <div class="form-row">
                    <div class="col-sm-4">
                        <label>Region</label>
                        <input type="text" value="@Model.OPT_Comuna.OPT_Region.Region" class="form-control form-control-sm" readonly />
                    </div>
                    <div class="col-sm-4">
                        <label>Comuna</label>
                        <input type="text" value="@Model.OPT_Comuna.Comuna" class="form-control form-control-sm" readonly />
                    </div>
                    <div class="col-sm-4">
                        <label>Direccion</label>
                        <input type="text" value="@Model.Direccion" class="form-control form-control-sm" readonly />
                    </div>
                </div>

                <div class="form-row">
                    <div class="col-sm-4">
                        <label>Celular</label>
                        <input type="text" value="@Model.Celular" class="form-control form-control-sm" readonly />
                    </div>
                    <div class="col-sm-4">
                        <label>Mail</label>
                        <input type="text" value="@Model.Mail" class="form-control form-control-sm" readonly />
                    </div>
                    <div class="col-sm-4">
                        <label>Fecha Ingreso</label>
                        <input type="text" value="@(DateTime.Parse(Model.FechaIngreso.ToString()).ToShortDateString())" class="form-control form-control-sm" readonly />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger btn-sm" data-dismiss="modal"><i class="fa fa-times"></i> Close</button>
            </div>
        </div>
    </div>
</div>
