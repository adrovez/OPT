@model PagedList.IPagedList<OPT.Entidad.DTO.OPT_ClienteDTO>
@using PagedList.Mvc;

@{
    Layout = null;
}



<table class="table table-sm table-hover">
    <thead>
        <tr class="text-center">
            <th>Empresa</th>
            <th>Rut</th>
            <th>Nombre</th>
            <th>Comuna</th>
            <th>Direccion</th>
            <th>Celular</th>
            <th>Accion</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var Item in Model)
        {
            <tr>
                <td>@Item.Empresa</td>
                <td>@Item.RutCliente</td>
                <td>@Item.Nombre</td>
                <td>@Item.Comuna</td>
                <td>@Item.Direccion</td>
                <td>@Item.Celular</td>
                <td class="text-center">
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline" type="button" data-toggle="dropdown">
                            <i class="fas fa-ellipsis-v"></i>
                        </button>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="@Url.Action("Details","Cliente",new {area="Clientes", id=Item.RutCliente })" name="Ver" title="Detalle..."><i class="fa fa-eye"></i> Ver</a></li>
                            <li><a class="dropdown-item" href="@Url.Action("Edit","Cliente",new {area="Clientes", id=Item.RutCliente })" name="Editar" title="Editar..."><i class="fa fa-edit"></i> Editar</a></li>
                            <li><a class="dropdown-item" href="@Url.Action("Details","FichaMedica",new {area="Clientes", id=Item.RutCliente })" name="FichaMedica" title="Ficha Medica..."><i class="fa fa-file-medical"></i> Ficha Medica</a></li>

                            @*<a href="@Url.Action("Historial","OT",new {area="OrdenTrabajo", id=Item.RutCliente })" name="Historial" class="btn btn-sm btn-outline-info" title="Historial..."><i class="fa fa-calendar"></i></a>
                                <a href="@Url.Action("Historial","Pago",new {area="OrdenTrabajo", id=Item.RutCliente })" name="Deuda" class="btn btn-sm btn-outline-success" title="Pagos..."><i class="fa fa-money-bill"></i></a>*@
                        </ul>
                    </div>
                </td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr class="text-center">
            <td colspan="7">
                Página @(Model.PageCount < Model.PageNumber ? 0 : Model.PageNumber) de @Model.PageCount
                @Html.PagedListPager(Model, pPageNumber => Url.Action("Paginar", "Cliente", new { pPageNumber }), new PagedListRenderOptions { FunctionToTransformEachPageLink = (liTag, aTag) => { aTag.Attributes.Add("name", "paginar"); liTag.InnerHtml = aTag.ToString(); return liTag; } })
            </td>
        </tr>
    </tfoot>
</table>

